[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    .tox,
    .eggs,
    *.egg-info,
    .mypy_cache,
    .pytest_cache,
    htmlcov

# E203: whitespace before ':' (conflicts with black)
# E501: line too long (we use 88 chars like black, not 79)
# W503: line break before binary operator (conflicts with black)

per-file-ignores =
    # F401: imported but unused (common in __init__.py)
    __init__.py:F401
    # Tests can have unused imports and redefinitions
    tests/*:F401,F811